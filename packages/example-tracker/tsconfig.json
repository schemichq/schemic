{
  "compilerOptions": {
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleResolution": "bundler",
    // Resolve @schemic/* via its "bun" export condition (-> src/*.ts) so the example
    // typechecks against source directly — no `bun run build` of the lib required.
    "customConditions": ["bun"],
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["bun", "vite/client"]
  },
  "include": ["src", "web", "test", "setup.ts", "vite.config.ts"],
  "exclude": ["node_modules", "dist"]
}
