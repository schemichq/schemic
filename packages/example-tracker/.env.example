# Root credentials for the admin migration script (setup.ts) and integration tests.
# Copy to `.env` and fill in. Never commit `.env`. The browser app does NOT use these
# — it authenticates as an end user via record access (signup/signin).
SURREAL_USER=root
SURREAL_PASS=
# Optional overrides (defaults shown):
# SURREAL_URL=ws://127.0.0.1:8000/rpc
# SURREAL_NS=surreal-zod
# SURREAL_DB=tracker
# SURREAL_ACCESS=account
