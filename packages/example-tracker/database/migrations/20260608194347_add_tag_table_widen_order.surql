    DEFINE FIELD OVERWRITE order ON TABLE project TYPE float DEFAULT 0;
} ELSE {
    REMOVE TABLE IF EXISTS tag;

    DEFINE FIELD OVERWRITE order ON TABLE project TYPE int DEFAULT 0;
