    DEFINE TABLE tag TYPE NORMAL SCHEMAFULL COMMENT "Reusable task labels" PERMISSIONS FOR select, create, update, delete WHERE project.owner = $auth.id OR project IN $auth->member->project;
    DEFINE FIELD project ON TABLE tag TYPE record<project>;
    DEFINE FIELD name ON TABLE tag TYPE string ASSERT string::len($value) >= 1;
    DEFINE FIELD color ON TABLE tag TYPE string DEFAULT "#999999";
