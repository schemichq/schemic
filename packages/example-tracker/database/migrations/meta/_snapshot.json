        "indexes": [],
        "events": [
          {
            "name": "stamp_completed_at",
            "table": "task",
            "native": {
              "name": "stamp_completed_at",
              "what": "task",
              "then": [
                "IF $after.status = \"done\" AND $after.completedAt = NONE {\n        UPDATE $after.id SET completedAt = time::now();\n      } ELSE IF $after.status != \"done\" AND $after.completedAt != NONE {\n        UPDATE $after.id SET completedAt = NONE;\n      }"
              ],
              "when": "$before.status != $after.status"
            }
          }
        ]
      },
