{
  "name": "@schemic/surreal",
  "version": "0.1.0-alpha.0",
  "description": "SurrealDB driver + authoring for Schemic — s.* schema definition, SurrealQL DDL, introspection, migrations.",
  "type": "module",
  "module": "lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "lib",
    "src"
  ],
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": {
        "types": "./lib/index.d.ts",
        "default": "./lib/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "prepack": "bun run build",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check ."
  },
  "dependencies": {
    "@schemic/core": "workspace:*",
    "surrealdb": "^2.0.3"
  },
  "peerDependencies": {
    "@surrealdb/node": "*",
    "zod": "^4.3.5"
  },
  "peerDependenciesMeta": {
    "@surrealdb/node": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@types/bun": "latest",
    "surrealdb": "^2.0.3",
    "tsup": "^8",
    "typescript": "^5",
    "zod": "^4.3.5"
  }
}
