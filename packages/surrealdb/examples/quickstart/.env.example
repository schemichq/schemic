# Point these at your SurrealDB. The config reads them explicitly (no implicit SURREAL_* magic) and
# falls back to a local dev server (ws://127.0.0.1:8000/rpc, root/root, ns demo / db quickstart).
SURREAL_URL=ws://127.0.0.1:8000/rpc
SURREAL_NAMESPACE=demo
SURREAL_DATABASE=quickstart
SURREAL_USER=root
SURREAL_PASS=root
