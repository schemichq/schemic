{
  "name": "@schemic/postgres",
  "version": "0.1.0-alpha.8",
  "description": "PostgreSQL driver for Schemic — emit/introspect/diff the portable IR against Postgres (PGlite).",
  "license": "MIT",
  "author": "Vertio Solutions",
  "homepage": "https://schemic.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/schemichq/schemic.git",
    "directory": "packages/postgres"
  },
  "type": "module",
  "sideEffects": ["./src/index.ts", "./lib/index.js"],
  "module": "lib/index.js",
  "types": "lib/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "lib",
    "src",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": {
        "types": "./lib/index.d.ts",
        "default": "./lib/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "prepack": "bun run build",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check ."
  },
  "dependencies": {
    "@schemic/core": "workspace:*",
    "zod": "^4.3.5"
  },
  "peerDependencies": {
    "@electric-sql/pglite": "^0.5.2"
  },
  "peerDependenciesMeta": {
    "@electric-sql/pglite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@electric-sql/pglite": "^0.5.2",
    "@types/bun": "latest",
    "tsup": "^8",
    "typescript": "^5"
  }
}
