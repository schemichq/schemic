{
  "name": "@schemic/core",
  "version": "0.1.0-alpha.0",
  "description": "Author SurrealDB schemas with Zod — s.* drop-in, SurrealQL DDL generation, and JS<->DB codecs.",
  "type": "module",
  "module": "lib/index.js",
  "types": "lib/index.d.ts",
  "bin": {
    "schemic": "lib/cli.js",
    "sc": "lib/cli.js"
  },
  "files": [
    "lib",
    "src"
  ],
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": {
        "types": "./lib/index.d.ts",
        "default": "./lib/index.js"
      }
    },
    "./config": {
      "bun": "./src/config.ts",
      "import": {
        "types": "./lib/config.d.ts",
        "default": "./lib/config.js"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "prepack": "bun run build",
    "test": "bun test",
    "test:unit": "bun test test/unit",
    "test:live": "bun test test/live",
    "test:e2e": "bun test test/e2e",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "commander": "^14.0.2",
    "jiti": "^2.4.2",
    "magicast": "^0.5.3"
  },
  "peerDependencies": {
    "surrealdb": "^2.0.3",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@types/bun": "latest",
    "surrealdb": "^2.0.3",
    "tsup": "^8",
    "typescript": "^5",
    "zod": "^4.3.5"
  }
}
