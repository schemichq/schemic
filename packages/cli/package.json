{
  "name": "@schemic/cli",
  "version": "0.1.0-alpha.0",
  "description": "The Schemic CLI — driver-agnostic schema migrations (gen/migrate/diff/push/pull/check).",
  "type": "module",
  "bin": {
    "schemic": "lib/cli.js",
    "sc": "lib/cli.js"
  },
  "files": [
    "lib",
    "src"
  ],
  "exports": {
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "prepack": "bun run build",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check ."
  },
  "dependencies": {
    "@schemic/core": "workspace:*",
    "commander": "^14.0.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@electric-sql/pglite": "^0.5.2",
    "@schemic/postgres": "workspace:*",
    "@schemic/surreal": "workspace:*",
    "@types/bun": "latest",
    "surrealdb": "^2.0.3",
    "tsup": "^8",
    "typescript": "^5",
    "zod": "^4.3.5"
  }
}
